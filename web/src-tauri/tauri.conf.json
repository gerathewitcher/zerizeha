{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Zerizeha",
  "version": "0.1.0",
  "identifier": "com.zerizeha.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run tauri:prep",
    "frontendDist": "../src-tauri/loader",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Zerizeha",
        "width": 1280,
        "height": 720,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "../.next/standalone/**",
      "../.next/static/**",
      "bin/node.exe"
    ]
  }
}
