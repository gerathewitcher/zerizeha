{
  "uid": "container-logs",
  "title": "Container Logs",
  "tags": [
    "logs",
    "docker"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "project",
        "type": "query",
        "datasource": "Loki",
        "refresh": 1,
        "includeAll": true,
        "multi": false,
        "allValue": ".*",
        "query": "label_values(compose_project)"
      },
      {
        "name": "service",
        "type": "query",
        "datasource": "Loki",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".*",
        "query": "label_values({compose_project=~\"$project\"}, compose_service)"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Logs",
      "datasource": "Loki",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{compose_project=~\"$project\", compose_service=~\"$service\"}"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Log rate by service",
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 14
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (compose_service) (rate({compose_project=~\"$project\", compose_service=~\"$service\"}[1m]))"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "bargauge",
      "title": "Top containers (5m rate)",
      "datasource": "Loki",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 14
      },
      "targets": [
        {
          "refId": "A",
          "expr": "topk(10, sum by (container) (rate({compose_project=~\"$project\"}[5m])))"
        }
      ],
      "options": {
        "displayMode": "basic",
        "orientation": "horizontal",
        "showUnfilled": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ops"
        },
        "overrides": []
      }
    }
  ]
}
